@page
@model EmployeeManagement.Api.Pages.ErrorModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="col-lg-7 mx-auto py-5">
    <div class="card border-danger">
        <div class="card-body p-4">
            <p class="text-danger fw-semibold mb-2">Error @Model.HttpStatusCode</p>
            <h1 class="h3">@Model.Title</h1>
            <p class="text-secondary">@Model.Detail</p>

            @if (!string.IsNullOrWhiteSpace(Model.TraceId))
            {
                <p class="small text-secondary mb-4">
                    Reference: <code>@Model.TraceId</code>
                </p>
            }

            <a asp-page="/Index" class="btn btn-primary">Return to employees</a>
        </div>
    </div>
</div>
